@{ 
    var controllerName = this.ViewContext.RouteData.Values["controller"].ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="" />

    <title>Edible</title>
    <link rel="icon" type="image/svg" href="~/img/em-favicon.svg" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600;1,700&family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Cardo:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

    <!-- Vendor CSS Files -->
    <link href="https://rprollingerjr.github.io/cuddly-enigma/assets/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://rprollingerjr.github.io/cuddly-enigma/assets/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="https://rprollingerjr.github.io/cuddly-enigma/assets/swiper/swiper-bundle.min.css" rel="stylesheet">
    <link href="https://rprollingerjr.github.io/cuddly-enigma/assets/glightbox/css/glightbox.min.css" rel="stylesheet">
    <link href="https://rprollingerjr.github.io/cuddly-enigma/assets/aos/aos.css" rel="stylesheet">

    <link href="https://rprollingerjr.github.io/cuddly-enigma/css/main.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>

    <!-- ======= Header ======= -->
    <!--add fixed-top class to header element, css needs to be updated to use this for pages with less content-->
    <header id="header" class="header d-flex align-items-center">
        <div class="container-fluid d-flex align-items-center justify-content-evenly">

            <a href="@Url.Action("Index", "Home")" class="logo d-flex align-items-center  me-auto me-lg-0">
                <!-- Uncomment the line below if you also wish to use an image logo -->
@*                <i class="pizza-girl"></i>
*@                <img src="~/img/em-horizontal.png" height="145" alt="">
                @*<h1>PhotoFolio</h1>*@
            </a>

            <nav id="navbar" class="navbar">
                <ul>
                    <li><a href="@Url.Action("Index", "Home")" class="active">Home</a></li>
                    <li><a href="@Url.Action("Index", "Events")">Events</a></li>
                </ul>
            </nav><!-- .navbar -->

            <div class="header-social-links">
                <a href="https://www.instagram.com/ediblemam1/" target="_blank" class="instagram"><i class="bi bi-instagram"></i></a>
                <a class="btn-get-started">Catering</a>
            </div>
            <i class="mobile-nav-toggle mobile-nav-show bi bi-list"></i>
            <i class="mobile-nav-toggle mobile-nav-hide d-none bi bi-x"></i>

        </div>
    </header><!-- End Header -->

    <main id="main" data-aos="fade" data-aos-delay="1500">
        @RenderBody()
    </main><!-- End #main -->



    <a href="#" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

    @if (controllerName == "Home") {
        <div id="preloader">
            <div class="line"></div>
        </div>
    }

    <!-- Vendor JS Files -->
    <script src="https://rprollingerjr.github.io/cuddly-enigma/assets/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="https://rprollingerjr.github.io/cuddly-enigma/assets/swiper/swiper-bundle.min.js"></script>
    <script src="https://rprollingerjr.github.io/cuddly-enigma/assets/glightbox/js/glightbox.min.js"></script>
    <script src="https://rprollingerjr.github.io/cuddly-enigma/assets/aos/aos.js"></script>

    <!-- Template Main JS File -->
    <script src="~/js/main.js"></script>
</body>
</html>