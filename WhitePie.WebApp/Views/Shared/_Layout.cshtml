@{ 
    var controllerName = this.ViewContext.RouteData.Values["controller"].ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="" />

    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/svg" href="~/img/em-favicon.svg" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600;1,700&family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Cardo:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

    <!-- Vendor CSS Files -->
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">
    <link href="/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">
    <link href="/vendor/aos/aos.css" rel="stylesheet">

    <link href="/styles/main.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>

    <!-- ======= Header ======= -->
    <header id="header" class="header d-flex align-items-center fixed-top">
        <div class="container-fluid d-flex align-items-center justify-content-between">

            <a href="@Url.Action("Index", "Home")" class="logo d-flex align-items-center  me-auto me-lg-0">
                <!-- Uncomment the line below if you also wish to use an image logo -->
@*                <i class="pizza-girl"></i>
*@                <img src="~/img/em-horizontal.png" height="145" alt="">
                @*<h1>PhotoFolio</h1>*@
            </a>

            <nav id="navbar" class="navbar">
                <ul>
                    <li><a href="@Url.Action("Index", "Home")" class="active">Home</a></li>
                    <li><a href="@Url.Action("Index", "Events")">Events</a></li>
                </ul>
            </nav><!-- .navbar -->

            <div class="header-social-links">
                <a href="https://www.instagram.com/ediblemam1/" target="_blank" class="instagram"><i class="bi bi-instagram"></i></a>
                <a href="@Url.Action("Index", "Contact")"><i class="bi bi-envelope"></i></a>
            </div>
            <i class="mobile-nav-toggle mobile-nav-show bi bi-list"></i>
            <i class="mobile-nav-toggle mobile-nav-hide d-none bi bi-x"></i>

        </div>
    </header><!-- End Header -->

    <main id="main">
        @if (TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertDanger] != null)
        {
            <div class="row" role="alert">
                <div class="col-12 col-md-6 offset-md-3">
                    <div class="alert alert-danger">@Html.Raw(TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertDanger])</div>
                </div>
            </div>
        }
        @if (TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertWarning] != null)
        {
            <div class="row">
                <div class="col-12 col-md-6 offset-md-3">
                    <div class="alert alert-warning">@Html.Raw(TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertWarning])</div>
                </div>
            </div>
        }
        @if (TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertSuccess] != null)
        {
            <div class="row">
                <div class="col-12 col-md-6 offset-md-3">
                    <div class="alert alert-success">@Html.Raw(TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertSuccess])</div>
                </div>
            </div>
        }
        @if (TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertInfo] != null)
        {
            <div class="row">
                <div class="col-12 col-md-6 offset-md-3">
                    <div class="alert alert-info">@Html.Raw(TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertInfo])</div>
                </div>
            </div>
        }
        @RenderBody()
    </main><!-- End #main -->

    <!-- ======= Footer ======= -->
    <footer class="text-center">
        <!-- Grid container -->
        <!-- Copyright -->
        <div class="text-center p-3" style="background-color: rgba(0, 0, 0, 0.2);">
            © 2023 
            <span role="button">EdibleMami LLC. All Rights Reserved.</span>
        </div>
        <!-- Copyright -->
    </footer><!-- End Footer -->

    <a href="#" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

    @if (controllerName == "Home") {
        <div id="preloader">
            <div class="line"></div>
        </div>
    }

    <!-- Vendor JS Files -->
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/swiper/swiper-bundle.min.js"></script>
    <script src="/vendor/glightbox/js/glightbox.min.js"></script>
    <script src="/vendor/aos/aos.js"></script>

    <!-- Template Main JS File -->
    <script src="~/js/main.js"></script>
</body>
</html>