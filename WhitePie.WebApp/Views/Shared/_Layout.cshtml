@{ 
    var controllerName = this.ViewContext.RouteData.Values["controller"].ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="" />

    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/svg" href="~/img/em-favicon.svg" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Patrick+Hand&display=swap" rel="stylesheet">

    <!-- Vendor CSS Files -->
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">
    <link href="/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">
    <link href="/vendor/aos/aos.css" rel="stylesheet">

    <link href="assets/styles/main.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>

    <!-- ======= Header ======= -->
    <header id="header" class="header d-flex align-items-center sticky-top">
        <div class="container-fluid position-relative d-flex align-items-center justify-content-between">

            <a href="index.html" class="logo d-flex align-items-center me-auto me-xl-0">
                <!-- Uncomment the line below if you also wish to use an image logo -->
                <img src="~/img/pizza.png" alt="Logo">
            </a>

            <nav id="navmenu" class="navmenu">
                <ul>
                    <li><a href="@Url.Action("Index", "Home")" class="active">Home<br></a></li>
                    <li><a href="@Url.Action("Index", "Events")">Events</a></li>
                    <li><a href="#">Revolving Menu</a></li>
                    <li><a href="#">About</a></li>
                    <li><a href="@Url.Action("Index", "Contact")">Book Me</a></li>
                </ul>
                <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
            </nav>

            <div class="header-social-links">
                <a href="https://www.instagram.com/ediblemamipizza/" target="_blank" rel="noopener noreferrer" class="instagram"><i class="bi bi-instagram"></i></a>
            </div>

        </div>
    </header>
    <!-- End Header -->

    <main class="main">
        @if (TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertDanger] != null)
        {
            <div class="row" role="alert">1
                <div class="col-12 col-md-6 offset-md-3">
                    <div class="alert alert-danger">@Html.Raw(TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertDanger])</div>
                </div>
            </div>
        }
        @if (TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertWarning] != null)
        {
            <div class="row">
                <div class="col-12 col-md-6 offset-md-3">
                    <div class="alert alert-warning">@Html.Raw(TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertWarning])</div>
                </div>
            </div>
        }
        @if (TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertSuccess] != null)
        {
            <div class="row">
                <div class="col-12 col-md-6 offset-md-3">
                    <div class="alert alert-success">@Html.Raw(TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertSuccess])</div>
                </div>
            </div>
        }
        @if (TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertInfo] != null)
        {
            <div class="row">
                <div class="col-12 col-md-6 offset-md-3">
                    <div class="alert alert-info">@Html.Raw(TempData[WhitePie.WebApp.Controllers.TempDataKey.AlertInfo])</div>
                </div>
            </div>
        }
        @RenderBody()
    </main><!-- End #main -->

    <!-- ======= Footer ======= -->
    <footer id="footer" class="footer">
        <div class="container">
            <div class="copyright text-center ">
                <p>© <span>Copyright</span> <strong class="px-1 sitename">EdibleMami, LLC</strong> <span>2024</span></p>
            </div>
            <div class="social-links d-flex justify-content-center">
                <a href=""><i class="bi bi-instagram"></i></a>
            </div>
        </div>

    </footer>
    <!-- End Footer -->

    <!-- Scroll Top -->
    <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-circle"></i></a>

    <!-- Template Main JS File -->
    <script src="assets/js/main.js"></script>

    <!-- Vendor JS Files -->
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/swiper/swiper-bundle.min.js"></script>
    <script src="/vendor/glightbox/js/glightbox.js"></script>
    <script src="/vendor/aos/aos.js"></script>

</body>
</html>